  "grammar_list": [
    {
      "title": "〜う/ようと思う",
      "meaning": "Berniat / Berpikir akan melakukan",
      "structure": "V-volitional + と思う (niat sesaat) / と思っている (niat berkelanjutan)",
      "example": "日本[にほん]に留学[りゅうがく]しようと思っている。"
    },
    {
      "title": "〜う/ようとする",
      "meaning": "Mencoba melakukan / Hampir / Akan",
      "structure": "V-volitional + とする (usaha) / としている (sedang akan)",
      "example": "ドア[どあ]を開[あ]けようとした。"
    },
    {
      "title": "〜う/ようとしない",
      "meaning": "Tidak mau / Tidak berniat melakukan (sikap negatif)",
      "structure": "V-volitional + としない (menolak / tidak berusaha)",
      "example": "彼[かれ]は勉強[べんきょう]しようとしない。"
    }
  ]
