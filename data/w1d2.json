  "grammar_list": [
    {
      "title": "〜ないと / 〜なくちゃ",
      "meaning": "Harus... / Kalau tidak... maka... (bentuk lisan singkat)",
      "structure": "V-nai stem + ないと / V-nai stem + なくちゃ (dari 〜ないといけない / 〜なくちゃいけない)",
      "example": "早[はや]く起[お]きないと。"
    },
    {
      "title": "〜ちゃう / 〜じゃう",
      "meaning": "Melakukan dengan tidak sengaja / Melakukan sepenuhnya (bentuk lisan 〜てしまう)",
      "structure": "V-te + ちゃう / V-de + じゃう (G1: 読む→読んじゃう, G2: 食べる→食べちゃう, G3: する→しちゃう, 来る→来ちゃう)",
      "example": "宿題[しゅくだい]を忘[わす]れちゃった。"
    },
    {
      "title": "〜とく / 〜どく",
      "meaning": "Melakukan sesuatu untuk persiapan / Melakukan di muka (bentuk lisan 〜ておく)",
      "structure": "V-te + とく / V-de + どく (G1: 読む→読んどく, G2: 食べる→食べとく, G3: する→しとく, 来る→来とく)",
      "example": "電気[でんき]を消[け]しとく。"
    }
  ]
